import java.util.LinkedList;
public class GenericSearch {

    public static <T> boolean searchElement(LinkedList<T> list, T element) {
        return list.contains(element);
    }

    public static void main(String[] args) {

        LinkedList<Integer> rollNumbers = new LinkedList<>();
        rollNumbers.add(101);
        rollNumbers.add(102);
        rollNumbers.add(103);
        rollNumbers.add(104);

        System.out.println("Searching 102 in roll numbers: "
                + searchElement(rollNumbers, 102));
        System.out.println("Searching 110 in roll numbers: "
                + searchElement(rollNumbers, 110));
        System.out.println("\n----------------------\n");

        LinkedList<String> names = new LinkedList<>();
        names.add("Rahul");
        names.add("Amit");
        names.add("Sneha");
        names.add("Priya");

        System.out.println("Searching 'Amit' in names: "
                + searchElement(names, "Amit"));
        System.out.println("Searching 'John' in names: "
                + searchElement(names, "John"));
    }
}
